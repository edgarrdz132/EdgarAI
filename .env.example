# ==========================================
# EdgarAI — Variables de Entorno
# ==========================================
# Copia este archivo como .env y rellena tus valores

# API Key de OpenAI
# Obtén la tuya en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-aqui-va-tu-api-key

# Modelo a usar (gpt-4o recomendado, también puedes usar gpt-4o-mini)
OPENAI_MODEL=gpt-4o

# Puerto del servidor
PORT=5000

# Modo debug (true en desarrollo, false en producción)
DEBUG=true
